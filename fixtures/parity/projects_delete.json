      "query": {
        "username": "user"
      },
      "response": {
        "status": 200,
        "json": {
          "projects": [
            {
              "_id": "aaaaaaaaaaaaaaaaaaaaaaaa",
              "slug": "road",
              "username": "user"
            }
          ]
        }
